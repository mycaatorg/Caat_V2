<file path="caat-frontend/components/resume-builder/ResumePreviewPanel.tsx">
"use client";

import React, {
  useEffect,
  useLayoutEffect,
  useMemo,
  useRef,
  useState,
} from "react";
import { ResumeSection } from "./types";

function safeText(x: any) {
  return typeof x === "string" ? x : "";
}

// A4 aspect ratio tied to the current preview width.
const PAGE_WIDTH_PX = 420;
const PAGE_HEIGHT_PX = PAGE_WIDTH_PX * Math.SQRT2;
// Use a conservative content budget so we never visually overflow
// the A4 box, even with margins, padding and measurement noise.
const PAGE_CONTENT_HEIGHT = PAGE_HEIGHT_PX * 0.8;
// Approximate vertical spacing between the personal header and first section
// (the "mt-8" on the sections container). We subtract this from the first
// page's content budget so pagination doesn't accidentally use that space.
const FIRST_PAGE_TOP_SPACING = 32;

type HtmlBlock = {
  id: string;
  sectionId: string;
  sectionLabel: string;
  html: string;
};

export type PageChunk = {
  pageIndex: number;
  sectionId: string;
  sectionLabel: string;
  includeSectionHeader: boolean;
  htmlBlocks: string[];
};

function splitNodeIntoChunks(
  baseId: string,
  sectionId: string,
  sectionLabel: string,
  node: HTMLElement,
  wordsPerChunk: number
): HtmlBlock[] {
  const text = node.textContent?.trim() ?? "";
  if (!text) {
    return [];
  }

  const words = text.split(/\s+/);
  if (words.length <= wordsPerChunk) {
    return [
      {
        id: `${baseId}-0`,
        sectionId,
        sectionLabel,
        html: node.outerHTML,
      },
    ];
  }

  const chunks: HtmlBlock[] = [];
  for (let i = 0; i < words.length; i += wordsPerChunk) {
    const slice = words.slice(i, i + wordsPerChunk).join(" ");

    const clone = node.cloneNode(false) as HTMLElement;
    clone.textContent = slice;

    chunks.push({
      id: `${baseId}-${i / wordsPerChunk}`,
      sectionId,
      sectionLabel,
      html: clone.outerHTML,
    });
  }

  return chunks;
}

function extractBlocksFromHtml(
  sectionId: string,
  sectionLabel: string,
  html: string
): HtmlBlock[] {
  if (typeof document === "undefined") return [];

  const container = document.createElement("div");
  container.innerHTML = html || "";

  const blocks: HtmlBlock[] = [];

  const children = Array.from(container.childNodes);
  children.forEach((node, index) => {
    // Bare text nodes -> paragraph chunks
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent?.trim() ?? "";
      if (!text) return;
      const wrapper = document.createElement("p");
      wrapper.textContent = text;
      blocks.push(
        ...splitNodeIntoChunks(
          `${sectionId}-text-${index}`,
          sectionId,
          sectionLabel,
          wrapper,
          18
        )
      );
      return;
    }

    if (node.nodeType !== Node.ELEMENT_NODE) return;

    const el = node as HTMLElement;
    const tag = el.tagName.toLowerCase();

    // Lists: split into one block per list item, and chunk long items.
    if (tag === "ul" || tag === "ol") {
      const items = Array.from(el.children).filter(
        (child) => child.tagName.toLowerCase() === "li"
      ) as HTMLElement[];

      items.forEach((li, liIndex) => {
        const liBaseId = `${sectionId}-li-${index}-${liIndex}`;
        const liChunks = splitNodeIntoChunks(
          liBaseId,
          sectionId,
          sectionLabel,
          li,
          16
        );

        liChunks.forEach((chunk, chunkIndex) => {
          // Wrap each li chunk back in its list container so bullets/indent stay correct.
          const temp = document.createElement(tag);
          temp.innerHTML = chunk.html;
          blocks.push({
            id: `${liBaseId}-${chunkIndex}`,
            sectionId,
            sectionLabel,
            html: temp.outerHTML,
          });
        });
      });
      return;
    }

    // Paragraph-like blocks: chunk when text is long, otherwise keep as-is.
    if (tag === "p" || tag === "div") {
      const text = el.textContent?.trim() ?? "";
      const wordCount = text ? text.split(/\s+/).length : 0;
      if (wordCount > 25) {
        blocks.push(
          ...splitNodeIntoChunks(
            `${sectionId}-block-${index}`,
            sectionId,
            sectionLabel,
            el,
            18
          )
        );
        return;
      }
    }

    const htmlString = el.outerHTML.trim();
    if (!htmlString) return;
    blocks.push({
      id: `${sectionId}-block-${index}`,
      sectionId,
      sectionLabel,
      html: htmlString,
    });
  });

  if (blocks.length === 0) {
    blocks.push({
      id: `${sectionId}-placeholder`,
      sectionId,
      sectionLabel,
      html: "<p class='text-muted-foreground'>...</p>",
    });
  }

  return blocks;
}

export default function ResumePreviewPanel({
  sections,
}: {
  sections: ResumeSection[];
}) {
  const personal = sections.find((s) => s.type === "personal")?.structuredData ?? {};
  const contentSections = useMemo(
    () => sections.filter((s) => s.type !== "personal"),
    [sections]
  );

  // Flattened list of HTML blocks in section order.
  const allBlocks = useMemo<HtmlBlock[]>(() => {
    if (typeof document === "undefined") return [];

    const result: HtmlBlock[] = [];
    contentSections.forEach((section) => {
      const blocks = extractBlocksFromHtml(
        section.id,
        section.label,
        section.contentHtml
      );
      result.push(...blocks);
    });
    return result;
  }, [contentSections]);

  const measurementRef = useRef<HTMLDivElement | null>(null);
  const [chunks, setChunks] = useState<PageChunk[]>([]);
  const [fontsReady, setFontsReady] = useState(false);

  // Wait for fonts to be ready before measuring, otherwise the first layout
  // pass may measure with fallback fonts and produce incorrect pagination
  // on the first page only.
  useEffect(() => {
    if (typeof document === "undefined") {
      setFontsReady(true);
      return;
    }

    const anyDoc = document as any;
    const fonts = anyDoc.fonts;
    if (fonts && fonts.ready) {
      fonts.ready
        .then(() => setFontsReady(true))
        .catch(() => setFontsReady(true));
    } else {
      setFontsReady(true);
    }
  }, []);

  // Measure layout and compute page chunks.
  useLayoutEffect(() => {
    if (!fontsReady || !measurementRef.current || allBlocks.length === 0) {
      setChunks([]);
      return;
    }

    const root = measurementRef.current;

    const headerEl = root.querySelector<HTMLElement>("[data-role='page-header']");
    const headerHeight = headerEl?.offsetHeight ?? 0;

    const sectionHeaderEls = Array.from(
      root.querySelectorAll<HTMLElement>("[data-section-header-id]")
    );
    const sectionHeaderHeights: Record<string, number> = {};
    sectionHeaderEls.forEach((el) => {
      const id = el.dataset.sectionHeaderId;
      if (!id) return;
      sectionHeaderHeights[id] = el.offsetHeight;
    });

    const blockEls = Array.from(
      root.querySelectorAll<HTMLElement>("[data-block-id]")
    );
    const blockHeights: Record<string, number> = {};
    blockEls.forEach((el) => {
      const id = el.dataset.blockId;
      if (!id) return;
      blockHeights[id] = el.offsetHeight;
    });

    const nextChunks: PageChunk[] = [];
    let currentPageIndex = 0;
    // First page has personal header + extra top spacing before sections.
    let remainingOnPage =
      PAGE_CONTENT_HEIGHT - headerHeight - FIRST_PAGE_TOP_SPACING;
    if (remainingOnPage < 0) remainingOnPage = 0;
    let hasBlocksOnCurrentPage = false;

    let currentChunk: PageChunk | null = null;

    const pushCurrentChunk = () => {
      if (currentChunk && currentChunk.htmlBlocks.length > 0) {
        nextChunks.push(currentChunk);
      }
      currentChunk = null;
    };

    const startNewPage = () => {
      pushCurrentChunk();
      currentPageIndex += 1;
      // Subsequent pages don't have the personal header or mt-8 spacing.
      remainingOnPage = PAGE_CONTENT_HEIGHT;
      hasBlocksOnCurrentPage = false;
    };

    const getSectionHeaderHeight = (sectionId: string) =>
      sectionHeaderHeights[sectionId] ?? 0;

    // Walk blocks in order and pack them into pages by block.
    allBlocks.forEach((block) => {
      const sectionHeaderHeight = getSectionHeaderHeight(block.sectionId);
      const blockHeight = blockHeights[block.id] ?? 0;

      // If we are switching sections on the same page, finish the previous chunk.
      if (currentChunk && currentChunk.sectionId !== block.sectionId) {
        pushCurrentChunk();
      }

      const needsSectionHeaderOnThisPage =
        !currentChunk || !currentChunk.includeSectionHeader;

      let headerCost = needsSectionHeaderOnThisPage ? sectionHeaderHeight : 0;
      let needed = headerCost + blockHeight;

      // If this block (and header) won't fit on the current page and the page
      // already has at least one block, move to a new page and recompute costs there.
      if (needed > remainingOnPage && hasBlocksOnCurrentPage) {
        startNewPage();
        headerCost = sectionHeaderHeight;
        needed = headerCost + blockHeight;
      }

      // Start a new chunk for this section on the current page if needed.
      if (!currentChunk) {
        currentChunk = {
          pageIndex: currentPageIndex,
          sectionId: block.sectionId,
          sectionLabel: block.sectionLabel,
          includeSectionHeader: headerCost > 0,
          htmlBlocks: [],
        };
      } else if (headerCost > 0 && !currentChunk.includeSectionHeader) {
        currentChunk.includeSectionHeader = true;
      }

      currentChunk.htmlBlocks.push(block.html);
      remainingOnPage = Math.max(0, remainingOnPage - needed);
      hasBlocksOnCurrentPage = true;
    });

    pushCurrentChunk();

    setChunks(nextChunks);
  }, [allBlocks, fontsReady]);

  // Group chunks by page index for rendering.
  const chunksByPage = useMemo(() => {
    if (!chunks.length) return {};
    return chunks.reduce<Record<number, PageChunk[]>>((acc, chunk) => {
      if (!acc[chunk.pageIndex]) acc[chunk.pageIndex] = [];
      acc[chunk.pageIndex].push(chunk);
      return acc;
    }, {});
  }, [chunks]);

  const pageIndices = useMemo(
    () => Object.keys(chunksByPage).map((k) => Number(k)).sort((a, b) => a - b),
    [chunksByPage]
  );

  // Fallback: single page with all sections if pagination hasn't run yet.
  const hasPagination = pageIndices.length > 0;

  return (
    <div className="border-l bg-muted/30 p-4 overflow-auto">
      <div className="mb-3 flex items-center justify-between text-xs text-muted-foreground">
        <div>A4</div>
        <div>Professional Resume Style</div>
        <div>100%</div>
      </div>

      {/* Hidden measurement container: same structure & styles as visible pages. */}
      <div
        ref={measurementRef}
        className="pointer-events-none fixed -left-2499.75 -top-2499.75 w-105 border bg-white p-10"
      >
        <div data-role="page-header">
          <div className="text-center">
            <div className="text-2xl font-bold tracking-wide">
              {safeText(personal.fullName) || "JOHN DOE"}
            </div>
            <div className="mt-1 text-[11px] text-muted-foreground">
              {safeText(personal.email) || "john@example.com"}
              {"  •  "}
              {safeText(personal.phone) || "+1 234 567 890"}
              {"  •  "}
              {safeText(personal.location) || "Sydney, Australia"}
              {"  •  "}
              <span className="text-blue-600 underline">
                {safeText(personal.linkedin) || "linkedin.com/in/johndoe"}
              </span>
            </div>
          </div>
        </div>

        <div className="mt-8">
          {contentSections.map((section) => {
            const blocksForSection = allBlocks.filter(
              (b) => b.sectionId === section.id
            );
            const headerId = section.id;

            return (
              <div key={section.id}>
                <div
                  data-section-header-id={headerId}
                  className="mb-3"
                >
                  <div className="text-[11px] font-bold tracking-wider">
                    {section.label.toUpperCase()}
                  </div>
                  <div className="mt-1 h-px w-full bg-black/40" />
                </div>

                {blocksForSection.map((block) => (
                  <div
                    key={block.id}
                    data-block-id={block.id}
                    className="resume-preview-content"
                    dangerouslySetInnerHTML={{ __html: block.html }}
                  />
                ))}
              </div>
            );
          })}
        </div>
      </div>

      {/* Visible paginated preview */}
      <div className="flex flex-col items-center gap-6">
        {hasPagination
          ? pageIndices.map((pageIndex) => {
              const pageChunks = chunksByPage[pageIndex] ?? [];

              return (
                <div
                  key={pageIndex}
                  className="mx-auto w-105 bg-white shadow-sm border p-10 overflow-hidden"
                  style={{ height: PAGE_HEIGHT_PX }}
                >
                  {pageIndex === 0 && (
                    <div className="text-center">
                      <div className="text-2xl font-bold tracking-wide">
                        {safeText(personal.fullName) || "JOHN DOE"}
                      </div>
                      <div className="mt-1 text-[11px] text-muted-foreground">
                        {safeText(personal.email) || "john@example.com"}
                        {"  •  "}
                        {safeText(personal.phone) || "+1 234 567 890"}
                        {"  •  "}
                        {safeText(personal.location) || "Sydney, Australia"}
                        {"  •  "}
                        <span className="text-blue-600 underline">
                          {safeText(personal.linkedin) ||
                            "linkedin.com/in/johndoe"}
                        </span>
                      </div>
                    </div>
                  )}

                  <div className={pageIndex === 0 ? "mt-8 space-y-6" : "space-y-6"}>
                    {pageChunks.map((chunk, idx) => (
                      <div key={`${chunk.sectionId}-${idx}`}>
                        {chunk.includeSectionHeader && (
                          <div className="mb-3">
                            <div className="text-[11px] font-bold tracking-wider">
                              {chunk.sectionLabel.toUpperCase()}
                            </div>
                            <div className="mt-1 h-px w-full bg-black/40" />
                          </div>
                        )}

                        {chunk.htmlBlocks.map((html, i) => (
                          <div
                            key={i}
                            className="resume-preview-content"
                            dangerouslySetInnerHTML={{ __html: html }}
                          />
                        ))}
                      </div>
                    ))}
                  </div>
                </div>
              );
            })
          : // Fallback single-page render while pagination hasn't run.
            (
              <div
                className="mx-auto w-105 bg-white shadow-sm border p-10 overflow-hidden"
                style={{ height: PAGE_HEIGHT_PX }}
              >
                <div className="text-center">
                  <div className="text-2xl font-bold tracking-wide">
                    {safeText(personal.fullName) || "JOHN DOE"}
                  </div>
                  <div className="mt-1 text-[11px] text-muted-foreground">
                    {safeText(personal.email) || "john@example.com"}
                    {"  •  "}
                    {safeText(personal.phone) || "+1 234 567 890"}
                    {"  •  "}
                    {safeText(personal.location) || "Sydney, Australia"}
                    {"  •  "}
                    <span className="text-blue-600 underline">
                      {safeText(personal.linkedin) || "linkedin.com/in/johndoe"}
                    </span>
                  </div>
                </div>

                <div className="mt-8 space-y-6">
                  {contentSections.map((section) => (
                    <div key={section.id}>
                      <div className="mb-3">
                        <div className="text-[11px] font-bold tracking-wider">
                          {section.label.toUpperCase()}
                        </div>
                        <div className="mt-1 h-px w-full bg-black/40" />
                      </div>
                      <div
                        className="resume-preview-content"
                        dangerouslySetInnerHTML={{
                          __html:
                            section.contentHtml ||
                            "<p class='text-muted-foreground'>...</p>",
                        }}
                      />
                    </div>
                  ))}
                </div>
              </div>
            )}
      </div>
    </div>
  );
}
